rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read/write access to all documents for authenticated users
    // This is suitable for development and testing
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // More specific rules for production (uncomment when ready)
    /*
    // Users collection - allow users to read/write their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Patrol data - allow authenticated users to read/write
    match /patrolData/{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Action reports - allow authenticated users to read/write
    match /actionReports/{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Incidents - allow authenticated users to read/write
    match /incidents/{document=**} {
      allow read, write: if request.auth != null;
    }
    */
  }
}
